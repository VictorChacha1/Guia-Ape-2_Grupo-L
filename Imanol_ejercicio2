include <iostream>
#include <string>

using namespace std;

void verAtributos(double saldos[], int index) {
    cout << "Cuenta #" << (index + 1) << " | Saldo actual: $" << saldos[index] << "\n";
}

void recibirDinero(double saldos[], int index, double monto) {
    if (monto > 0) {
        saldos[index] += monto;
        cout << "Deposito exitoso.\n";
    } else {
        cout << "Error: Monto invalido.\n";
    }
}

void enviarDinero(double saldos[], int index, double monto) {
    if (monto > 0 && saldos[index] >= monto) {
        saldos[index] -= monto;
        cout << "Envio / Retiro exitoso.\n";
    } else {
        cout << "Error: Fondos insuficientes o monto invalido.\n";
    }
}

void transferir(double saldos[], int origen, int destino, double monto) {
    if (monto > 0 && saldos[origen] >= monto) {
        saldos[origen] -= monto;
        saldos[destino] += monto;
        cout << "Transferencia exitosa.\n";
    } else {
        cout << "Error: Fondos insuficientes para transferir.\n";
    }
}

int main() {
    string dni;
    double saldos[3] = {0.0, 0.0, 0.0};
    int opcion, num, dest;
    double monto;

    cout << "===== REGISTRO DE CLIENTE =====\n";
    cout << "Ingrese su DNI: ";
    cin >> dni;

    do {
        cout << "\n=== MENU BANCARIO (Cliente: " << dni << ") ===\n";
        cout << "1. Ver atributos de la cuenta (Saldo)\n";
        cout << "2. Recibir dinero (Depositar)\n";
        cout << "3. Enviar dinero (Retirar)\n";
        cout << "4. Transferencia entre cuentas\n";
        cout << "5. Salir\n";
        cout << "Seleccione una opcion: ";
        cin >> opcion;

        if (opcion >= 1 && opcion <= 3) {
            cout << "Seleccione la cuenta -> 1, 2 o 3: ";
            cin >> num;
            num--;
        }

        switch (opcion) {
            case 1:
                verAtributos(saldos, num);
                break;
            case 2:
                cout << "Monto a recibir: $";
                cin >> monto;
                recibirDinero(saldos, num, monto);
                break;
            case 3:
                cout << "Monto a enviar: $";
                cin >> monto;
                enviarDinero(saldos, num, monto);
                break;
            case 4:
                cout << "Cuenta de ORIGEN -> 1, 2 o 3: ";
                cin >> num;
                num--;
                cout << "Cuenta de DESTINO -> 1, 2 o 3: ";
                cin >> dest;
                dest--;

                cout << "Monto a transferir: $";
                cin >> monto;

                if (num != dest) {
                    transferir(saldos, num, dest, monto);
                } else {
                    cout << "Error: No puedes transferir a la misma cuenta.\n";
                }
                break;
            case 5:
                cout << "Saliendo del sistema...\n";
                break;
            default:
                cout << "Opcion invalida.\n";
        }
    } while (opcion != 5);

    return 0;
}

