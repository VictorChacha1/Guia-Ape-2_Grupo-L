Jean.h
#ifndef JEAN_H
#define JEAN_H
#include <iostream>
#include <string>
using namespace std;

class Jean {
private:
    string codigo, color, talla, estadoTela;
    bool tenido;
    int cantidadTenidos, cantidadBotones;
    float precio, humedad;

public:
    Jean();
    void IngresarDatos();
    void MostrarDatos();
    void Lavar();
    void Secar();
};
#endif
//======================================================================================================//

//======================================================================================================//
Jean.cpp
#include "Jean.h"

Jean::Jean() {
    codigo = color = talla = estadoTela = "";
    tenido = false;
    cantidadTenidos = cantidadBotones = 0;
    precio = humedad = 0;
}

void Jean::IngresarDatos() {
    cout << "Codigo: "; cin >> codigo;
    cout << "Color: "; cin >> color;
    cout << "Talla: "; cin >> talla;
    cout << "Tenido -> (1=Si, 0=No): "; cin >> tenido;
    cout << "Cantidad de tenidos: "; cin >> cantidadTenidos;
    cout << "Precio: "; cin >> precio;
    cout << "Botones: "; cin >> cantidadBotones;
    cout << "Humedad: "; cin >> humedad;
    cout << "Estado tela: "; cin >> estadoTela;
}

void Jean::MostrarDatos() {
    cout << "\nCodigo: " << codigo << "\nColor: " << color << "\nHumedad: " << humedad << "%" << endl;
}

void Jean::Lavar() {
    if (cantidadTenidos > 0) {
        cantidadTenidos--;
        cout << "Jean lavado. Tenidos: " << cantidadTenidos << endl;
    }
}

void Jean::Secar() {
    if (humedad > 0) {
        humedad -= 10;
        if (humedad < 0) humedad = 0;
        cout << "Jean secado. Humedad: " << humedad << "%" << endl;
    }
}
//======================================================================================================//

//======================================================================================================//
main.cpp
#include "Jean.h"

int main() {
    Jean jean;
    int opcion;
    do {
        cout << "=======MENU DE JEAN=======";
        cout << "\n1.Ingresar";
        cout << "\n2.Mostrar";
        cout << "\n3.Lavar";
        cout << "\n4.Secar";
        cout << "\n5.Salir";
        cout << "\nOpcion: ";
        cin >> opcion;
        switch(opcion) {
            case 1: jean.IngresarDatos(); break;
            case 2: jean.MostrarDatos(); break;
            case 3: jean.Lavar(); break;
            case 4: jean.Secar(); break;
        }
    } while (opcion != 5);
    return 0;
}
